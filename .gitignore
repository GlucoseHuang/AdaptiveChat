# ------------------------------------------------
# Streamlit
# ------------------------------------------------
# 忽略 Streamlit 的密钥文件和配置文件，防止 API Key 等敏感信息泄露
.streamlit/

# ------------------------------------------------
# Python 编译文件与缓存
# ------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ------------------------------------------------
# 虚拟环境 (Virtual Environments)
# ------------------------------------------------
venv/
.venv/
env/
.env/
my_env/

# ------------------------------------------------
# IDE 和编辑器配置
# ------------------------------------------------
.vscode/
.idea/
*.iml

# ------------------------------------------------
# macOS 系统文件
# ------------------------------------------------
.DS_Store
Icon
Iconr
._*

# ------------------------------------------------
# 包管理与构建文件
# ------------------------------------------------
dist/
build/
*.egg-info/
.eggs/

# ------------------------------------------------
# Jupyter Notebook
# ------------------------------------------------
.ipynb_checkpoints/
.ipynb_output/
*.ipynb_checkpoints/

# ------------------------------------------------
# 项目评分 Prompt 模板
# ------------------------------------------------
system_prompts.json
system_prompts_detail.json

# ------------------------------------------------
# 日志与实验数据
# ------------------------------------------------
experiment_logs/
*.log

# ------------------------------------------------
# 备份文件
# ------------------------------------------------
backup/

# ------------------------------------------------
# 敏感信息（不区分大小写）
# ------------------------------------------------
*secret*
*password*
*.pem
*.key
